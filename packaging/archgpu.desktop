[Desktop Entry]
Type=Application
Version=1.5
Name=ArchGPU
GenericName=Graphics & Gaming Configurator
Comment=Multi-vendor GPU, Wayland, bootloader, and gaming stack configurator for Arch Linux
Exec=pkexec /usr/bin/archgpu
Icon=preferences-system
Terminal=false
